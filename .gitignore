.DS_Store
.env
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
build/
dist/
site/

# LTspice and generated simulation artifacts
runs/*
!runs/.gitkeep
*.raw
*.op.raw
!tests/fixtures/*.raw
*.log
!tests/fixtures/*.log
*.db
*.exe.log
*.net
examples/**/generated/

# Keep generated documentation assets opt-in.
docs-site/site/
docs-site/pages/assets/generated/*
!docs-site/pages/assets/generated/.gitkeep
!docs-site/pages/assets/generated/opamp-summing.svg
!docs-site/pages/assets/generated/sallen-key-lowpass.svg
examples/transient/*/*.svg

# MCP/runtime sidecars
.ltspice-mcp/
